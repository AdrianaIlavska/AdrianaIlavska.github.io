source = "oecd_sdmx",
start_period = stringr::str_extract(URL, "(?<=startPeriod=)\\d{4}-\\d{2}"),
dimension_at_observation = stringr::str_extract(URL, "(?<=dimensionAtObservation=)[^&]+"),
format = stringr::str_extract(URL, "(?<=format=)[^&]+"),
base_url = stringr::str_replace(URL, "\\?.*$", ""),
query_params = stringr::str_replace(URL, "^[^?]*\\?", "")
) %>%
select(
source, Dataset, Measure, Measure.Dataset.Description,
Unit.Transformation.Adjustment, Area.Available,
base_url, query_params, start_period, dimension_at_observation, format,
API, URL
) %>%
rename(
dataset_name = Dataset,
description = Measure.Dataset.Description,
unit_transformation_adjustment = Unit.Transformation.Adjustment,
areas_available = Area.Available,
url_api = API,
url_csv = URL
)
