library(eurostat)
toc <- get_eurostat_toc()
monthly_toc <- toc %>%
filter(grepl("- monthly data", title, ignore.case = TRUE)) %>%
filter(type != "folder") %>%
mutate(
data_end_clean = case_when(
grepl("^\\d{4}-\\d{2}$", data.end) ~ paste0(data.end, "-01"),
grepl("^\\d{4}$",       data.end) ~ paste0(data.end, "-12-31"),
TRUE ~ data.end
),
data_end_date = suppressWarnings(ymd(data_end_clean))
)
eurostat_data <- monthly_toc %>%
filter(data_end_date > as.Date("2025-09-01"))
# Canonical Eurostat SDMX 2.1 full dataset TSV (matches your observed request)
eurostat_parsed <- eurostat_data %>%
transmute(
source = "eurostat",
dataset_name = code,
measure = NA_character_,  # Eurostat datasets don’t have your "Measure" concept here
title,
type,
last_update_of_data = `last.update.of.data`,
last_table_structure = `last.table.structure…¹`,
data_start = data.start,
data_end = data.end,
values,
hierarchy,
base_url = paste0("https://ec.europa.eu/eurostat/api/dissemination/sdmx/2.1/data/", code),
query_params = "format=TSV&compressed=true"
)
# Canonical Eurostat SDMX 2.1 full dataset TSV (matches your observed request)
eurostat_parsed <- eurostat_data %>%
transmute(
source = "eurostat",
dataset_name = code,
measure = NA_character_,  # Eurostat datasets don’t have your "Measure" concept here
title,
type,
last_update_of_data = `last.update.of.data`,
data_start = data.start,
data_end = data.end,
values,
hierarchy,
base_url = paste0("https://ec.europa.eu/eurostat/api/dissemination/sdmx/2.1/data/", code),
query_params = "format=TSV&compressed=true"
)
# --- 3) Eurostat ingestion inventory (bronze config) ---
eurostat_ingestion_inventory <- eurostat_parsed %>%
transmute(
source,
dataset_name,
measure,
base_url,
query_params,
expected_file_ext = "tsv.gz",
partition_hint = "source=eurostat/dataset_name={dataset_name}/ingestion_date={YYYY-MM-DD}"
) %>%
distinct()
# --- 4) Eurostat metadata reference ---
eurostat_metadata <- eurostat_parsed %>%
transmute(
source,
dataset_name,
title,
type,
last_update_of_data,
last_table_structure,
data_start,
data_end,
values,
hierarchy
) %>%
distinct()
# --- 4) Eurostat metadata reference ---
eurostat_metadata <- eurostat_parsed %>%
transmute(
source,
dataset_name,
title,
type,
last_update_of_data,
data_start,
data_end,
values,
hierarchy
) %>%
distinct()
