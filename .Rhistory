sep = ";"
)
# ==============================================================================
# OECD
# ==============================================================================
OECD_variables <- read.csv(
"OECD_variables_list.csv",
sep = ";"
)
# keep your existing cleaning intent
OECD_variables <- OECD_variables[which(OECD_variables$Dataset != ""), -5]
# create CSV URL
OECD_variables$URL <- paste0(OECD_variables$API, "&format=csvfilewithlabels")
# Parse URL into base + query params
oecd_parsed <- OECD_variables %>%
mutate(
source = "oecd_sdmx",
base_url = str_replace(URL, "\\?.*$", ""),
query_params = str_replace(URL, "^[^?]*\\?", "")
) %>%
rename(
dataset_name = Dataset,
measure = Measure,
description = Measure.Dataset.Description,
unit_transformation_adjustment = Unit.Transformation.Adjustment,
areas_available = Area.Available
)
# --- 1) OECD ingestion inventory (bronze config) ---
oecd_ingestion_inventory <- oecd_parsed %>%
transmute(
source,
dataset_name,
measure,
base_url,
query_params,
expected_file_ext = "csv",
partition_hint = "source=oecd_sdmx/dataset_name={dataset_name}/measure={measure}/ingestion_date={YYYY-MM-DD}"
) %>%
distinct()
# --- 2) OECD metadata reference (semantics, for silver/gold or documentation) ---
oecd_metadata <- oecd_parsed %>%
transmute(
source,
dataset_name,
measure,
description,
unit_transformation_adjustment,
areas_available
) %>%
distinct()
# Write OECD outputs
write_csv(oecd_ingestion_inventory, "oecd_ingestion_inventory.csv")
write_csv(oecd_metadata,            "oecd_metadata.csv")
