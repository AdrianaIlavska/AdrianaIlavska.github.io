library(jsonlite)
df <- fromJSON("index.js")
# read the JS file
txt <- readLines("index.js")
# collapse to single string
txt <- paste(txt, collapse = "\n")
# extract the JSON array
json_part <- str_extract(txt, "const data = \\[(.|\\n)*?\\];")
# remove "const data =" and trailing ";"
json_part <- str_remove(json_part, "^const data = ")
json_part <- str_remove(json_part, ";$")
# parse JSON
df <- fromJSON(json_part)
txt <- readLines("index.js") |> paste(collapse = "\n")
# extract the data array
json_part <- str_extract(txt, "const data = \\[(.|\\n)*?\\];")
# remove wrapper
json_part <- str_remove(json_part, "^const data = ")
json_part <- str_remove(json_part, ";$")
# convert JS object syntax to JSON
json_part <- str_replace_all(json_part, "(\\w+)\\s*:", "\"\\1\":")
json_part <- str_replace_all(json_part, "'", "\"")
# parse
df <- fromJSON(json_part)
jason_part
json_part
validate(json_part)
json_fixed <- gsub('"USA"', 'USA', json_part, fixed = TRUE)
validate(json_fixed)
# parse
df <- fromJSON(json_fixed)
