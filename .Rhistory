# Prepare data for XGBoost (entire dataset)
dtrain_full <- xgb.DMatrix(data = as.matrix(df[, -c(1,which(colnames(df) == "Target"))]),
label = df$Target)
# Train the final model
final_model <- xgb.train(
params = list(
objective = "reg:squarederror",
eval_metric = "rmse",
max_depth = 3,
eta = 0.1
),
data = dtrain_full,
nrounds = 50
)
# Example: Predict on new data
# Replace `new_data` with your actual new dataset
#c(1,which(colnames(data) == DV),c(12:ncol(data)))
new_data <- for_prediction[, c(1,which(colnames(for_prediction) == DV),c(17:ncol(for_prediction)))]  # Example subset without Target
data_for_prediction <- new_data[,-c(1:2)]
dnew <- xgb.DMatrix(data = as.matrix(data_for_prediction))
# Make predictions
predictions <- predict(final_model, newdata = dnew)
new_data <- new_data[,c(1,2)]
new_data[,2] <- predictions
XGBoost <- merge(XGBoost, new_data)
df <- df[, colSums(is.na(df)) == 0]
##### ##### ##### ##### ##### #####
##### Random Forest
## I really have to exclude all that are missing
# in df I have those that are in trainign data
keep_vars <- colnames(df)
# Subset the new data for prediction - but only those that are also in df, because I
new_data <- for_prediction[, c(1, which(colnames(for_prediction) == DV), c(17:ncol(for_prediction)))]
# Prepare the data for prediction
data_for_prediction <- new_data[, -c(1:2)]  # Exclude date and target columns
# Remove columns with NAs in the prediction dataset
data_for_prediction <- data_for_prediction[, which(colnames(data_for_prediction) %in% colnames(df))]
data_for_prediction <- data_for_prediction[, colSums(is.na(data_for_prediction)) == 0]
df <- df[,c(1,2,
which(colnames(df) %in% colnames(data_for_prediction)))]
# Perform cross-validation
rf_results <- lapply(folds, function(train_index) {
# Split data into training and testing
train_data <- df[train_index, -1]
test_data <- df[-train_index, -1]
# Train Random Forest model
model <- randomForest(
Target ~ .,
data = train_data,
ntree = 100,  # Number of trees
mtry = floor(sqrt(ncol(train_data) - 1))  # Number of features tried at each split
)
# Make predictions
predictions <- predict(model, newdata = test_data)
# Calculate RMSE
RMSE <- sqrt(mean((test_data$Target - predictions)^2))
return(RMSE)
})
# Average RMSE across all folds
mean_rf_rmse <- mean(unlist(rf_results))
summary_of_models$randomForest[which(summary_of_models$DV == DV)] <- mean_rf_rmse
# Train the final model on the entire dataset
final_rf_model <- randomForest(
Target ~ .,
data = df[, -1],
ntree = 100,  # Number of trees
mtry = floor(sqrt(ncol(df[, -1]) - 1))  # Number of features tried at each split
)
# Make predictions using the final Random Forest model
predictions <- predict(final_rf_model, newdata = data_for_prediction)
# Add predictions to the original data
new_data <- new_data[, c(1, 2)]  # Retain only the date and target columns
new_data[, 2] <- predictions      # Replace the target column with predictions
# Merge predictions back into the main dataset (if needed)
randomForest <- merge(randomForest, new_data, all = TRUE)
} # for the main loop through all DVs
View(XGBoost)
write.csv(summary_of_models, paste0('xgb_rf_summary_models.csv'), row.names = FALSE)
write.csv(XGBoost, paste0('xgb_forecasts.csv'), row.names = FALSE)
write.csv(randomForest, paste0('rf_predictions.csv'), row.names = FALSE)
View(summary_of_models)
